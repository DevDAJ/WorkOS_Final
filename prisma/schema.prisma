generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Proficiency {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  NATIVE
}

enum SkillCategory {
  LANGUAGE
  FRAMEWORK
  TOOL
  DATABASE
  CLOUD
  SOFT_SKILL
  OTHER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  image        String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  personalInfo   PersonalInfo?
  education      Education[]
  workExperience WorkExperience[]
  projects       Project[]
  skills         Skill[]
  certifications Certification[]
  awards         Award[]
  languages      Language[]
  references     Reference[]
  socialLinks    SocialLink[]
  sessions       Session[]
  careerMatches  CareerMatch[]
  careerQuests   CareerQuest[]
  applications   Application[]
  postedJobs     Job[]      @relation("PostedJobs")
  careerMapCache Json?
}

model PersonalInfo {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline  String?
  summary   String?
  phone     String?
  location  String?
  photo     String?
  title     String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Education {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution String
  degree      String
  field       String
  startDate   DateTime
  endDate     DateTime?
  gpa         Float?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkExperience {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      String
  role         String
  location     String?
  startDate    DateTime
  endDate      DateTime?
  current      Boolean  @default(false)
  description  String?
  bulletPoints String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title               String
  description         String?
  role                String?
  teamSize            Int?
  duration            String?
  status              String?
  repoUrl             String?
  demoUrl             String?
  technologies        String[]
  skillsDemonstrated  String[]
  responsibilities    String[]
  featuresBuilt       String[]
  challenges          String?
  lessonsLearned      String?
  tags                String[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Skill {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  category          SkillCategory @default(OTHER)
  confidenceScore   Float?
  yearsOfExperience Float?
  relatedSkills     String[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  evidence SkillEvidence[]

  @@unique([userId, name])
}

model SkillEvidence {
  id        String @id @default(cuid())
  skillId   String
  skill     Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  source    String
  sourceId  String
  confirmed Boolean @default(false)

  @@unique([skillId, source, sourceId])
}

model Certification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  issuer      String
  date        DateTime?
  url         String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Award {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  issuer      String?
  date        DateTime?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Language {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  proficiency Proficiency
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([userId, name])
}

model Reference {
  id           String @id @default(cuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  email        String?
  phone        String?
  company      String?
  role         String?
  relationship String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SocialLink {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum RoleCategory {
  FRONTEND
  BACKEND
  DEVOPS
  FULLSTACK
  DATA
  ML
  MOBILE
  DESIGN
  PM
  QA
  SRE
  SECURITY
  OTHER
}

enum SeniorityLevel {
  JUNIOR
  MID
  SENIOR
  STAFF
  PRINCIPAL
}

enum EdgeCategory {
  NEXT
  STRETCH
  LONG_TERM
}

enum QuestStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  PENDING
  COMPLETED
  SKIPPED
}

model CareerRole {
  id          String        @id @default(cuid())
  name        String        @unique
  category    RoleCategory
  seniority   SeniorityLevel
  description String?

  outgoingEdges CareerPathEdge[]       @relation("FromRole")
  incomingEdges CareerPathEdge[]       @relation("ToRole")
  requirements  RoleSkillRequirement[]
  matches       CareerMatch[]
  quests        CareerQuest[]
}

model CareerPathEdge {
  id                 String       @id @default(cuid())
  fromRoleId         String
  toRoleId           String
  category           EdgeCategory
  requiredSkillScore Float        @default(0)

  fromRole CareerRole @relation("FromRole", fields: [fromRoleId], references: [id], onDelete: Cascade)
  toRole   CareerRole @relation("ToRole", fields: [toRoleId], references: [id], onDelete: Cascade)

  @@unique([fromRoleId, toRoleId])
}

model RoleSkillRequirement {
  id         String   @id @default(cuid())
  roleId     String
  skillName  String
  weight     Float    @default(1)
  isOptional Boolean  @default(false)
  minYears   Float?

  role CareerRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, skillName])
}

model CareerMatch {
  id            String   @id @default(cuid())
  userId        String
  roleId        String
  matchScore    Float
  strengths     String[]
  gaps          String[]
  partialMatches String[]
  breakdown     String   @default("{}")
  computedAt    DateTime @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role CareerRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model CareerQuest {
  id          String      @id @default(cuid())
  userId      String
  roleId      String
  title       String
  description String?
  progress    Float       @default(0)
  status      QuestStatus @default(ACTIVE)
  rewardScore Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role  CareerRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tasks QuestTask[]
}

model QuestTask {
  id             String     @id @default(cuid())
  questId        String
  description    String
  skillName      String?
  skillWeight    Float      @default(1)
  linkedProjectId String?
  status         TaskStatus @default(PENDING)
  createdAt      DateTime   @default(now())
  completedAt    DateTime?

  quest CareerQuest @relation(fields: [questId], references: [id], onDelete: Cascade)
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  FREELANCE
}

enum LocationType {
  REMOTE
  HYBRID
  ON_SITE
}

enum JobStatus {
  ACTIVE
  DRAFT
  CLOSED
  FILLED
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  INTERVIEWED
  OFFERED
  REJECTED
  WITHDRAWN
}

model Job {
  id               String            @id @default(cuid())
  title            String
  company          String
  companyLogo      String?
  companyWebsite   String?
  companySize      String?
  location         String?
  locationType     LocationType      @default(ON_SITE)
  description      String
  responsibilities String[]
  requirements     String[]
  niceToHave       String[]
  salaryMin        Int?
  salaryMax        Int?
  salaryCurrency   String            @default("USD")
  type             JobType           @default(FULL_TIME)
  category         RoleCategory
  seniority        SeniorityLevel
  skills           String[]
  status           JobStatus         @default(ACTIVE)
  postedById       String?
  postedBy         User?             @relation("PostedJobs", fields: [postedById], references: [id], onDelete: SetNull)
  applicationCount Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  applications Application[]
}

model Application {
  id          String            @id @default(cuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      ApplicationStatus @default(PENDING)
  coverLetter String?
  resumeUrl   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, userId])
}
